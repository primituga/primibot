# --- Discord Credentials ---
DISCORD_TOKEN=your_discord_token_here

# --- Twitch Credentials ---
TWITCH_BOT_ID=your_twitch_bot_id

#    ACCESS TOKEN  -> https://twitchtokengenerator.com/
TWITCH_TOKEN=oauth:your_twitch_token_here

#    TTV Channels to bot use
TWITCH_CHANNEL=your_channel_name

#    https://dev.twitch.tv/console -> CLIENT ID
TWITCH_CLIENT_ID=your_client_id

#    https://dev.twitch.tv/console
TWITCH_CLIENT_SECRET=your_client_secret

# --- AI Credentials (Flowise & Groq) ---
FLOW_ID=your_flowise_chatflow_id

# --- Credenciais IA (Flowise e Groq) ---
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- Local Infrastructure ---
REDIS_URL=redis://redis:6379/0
OLLAMA_BASE_URL=http://ollama:11434
SEARXNG_URL=http://searxng:8080/search
